import { useEffect, useState } from 'react';
import './index.css';
import Logo from './components/Logo';
import { translations } from './translations';

function App() {
  const [scrolled, setScrolled] = useState(false);
  const [lang, setLang] = useState<'en' | 'es'>('en');

  const t = translations[lang];

  useEffect(() => {
    const handleScroll = () => {
      setScrolled(window.scrollY > 50);
    };
    window.addEventListener('scroll', handleScroll);
    return () => window.removeEventListener('scroll', handleScroll);
  }, []);

  return (
    <>
      <header style={{
        boxShadow: scrolled ? '0 4px 20px rgba(0,0,0,0.5)' : 'none'
      }}>
        <div className="top-bar" style={{
          background: scrolled ? 'var(--bg-dark)' : 'var(--primary-dark)',
          transition: 'background 0.3s ease'
        }}>
          <a href="#" className="logo-container" style={{ display: 'flex', alignItems: 'center' }}>
            <Logo
              className="app-logo header-logo"
              style={{ height: '100%', alignItems: 'center' }}
            />
          </a>

          <div className="top-links">
            <button onClick={() => document.getElementById('solutions')?.scrollIntoView({ behavior: 'smooth' })}>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M12 16v-4"></path><path d="M12 8h.01"></path></svg>
              {t.history}
            </button>
            <button onClick={() => document.getElementById('industries')?.scrollIntoView({ behavior: 'smooth' })}>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
              {t.ourValues}
            </button>
            <button onClick={() => document.getElementById('solutions')?.scrollIntoView({ behavior: 'smooth' })}>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"></path><circle cx="12" cy="10" r="3"></circle></svg>
              {t.locations}
            </button>
            <button onClick={() => document.getElementById('contact')?.scrollIntoView({ behavior: 'smooth' })}>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="m22 7-8.991 5.727a2 2 0 0 1-2.009 0L2 7"></path><rect x="2" y="4" width="20" height="16" rx="2"></rect></svg>
              {t.contact}
            </button>
            <select
              value={lang}
              onChange={(e) => setLang(e.target.value as 'en' | 'es')}
              style={{
                background: 'transparent',
                color: 'white',
                border: 'none',
                cursor: 'pointer',
                fontFamily: 'inherit',
                fontWeight: 800,
                fontSize: '13px',
                outline: 'none',
                marginLeft: '8px'
              }}
            >
              <option value="en" style={{ color: '#000' }}>EN</option>
              <option value="es" style={{ color: '#000' }}>ES</option>
            </select>
          </div>
        </div>

        <div className="bottom-bar" style={{
          display: scrolled ? 'none' : 'flex',
          transform: scrolled ? 'translateY(-100%)' : 'translateY(0)',
          transition: 'all 0.3s ease',
          opacity: scrolled ? 0 : 1
        }}>
          <nav className="bottom-nav">
            <button onClick={() => document.getElementById('innovation')?.scrollIntoView({ behavior: 'smooth' })}>{t.products} <div className="nav-underline"></div></button>
            <button onClick={() => document.getElementById('innovation')?.scrollIntoView({ behavior: 'smooth' })}>{t.capabilities} <div className="nav-underline"></div></button>
            <button onClick={() => document.getElementById('projects')?.scrollIntoView({ behavior: 'smooth' })}>{t.industries} <div className="nav-underline"></div></button>
            <button onClick={() => document.getElementById('who-we-are')?.scrollIntoView({ behavior: 'smooth' })}>{t.quality} <div className="nav-underline"></div></button>
            <button onClick={() => document.getElementById('contact')?.scrollIntoView({ behavior: 'smooth' })}>{t.company} <div className="nav-underline"></div></button>
          </nav>

          <div className="search-box">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary-dark)" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" style={{ position: 'absolute', left: '16px', top: '50%', transform: 'translateY(-50%)' }}><path d="m21 21-4.34-4.34"></path><circle cx="11" cy="11" r="8"></circle></svg>
            <input type="text" placeholder={t.searchPlaceholder} />
          </div>
        </div>
      </header>

      {/* Hero Section with Full-Screen Background Video */}
      <section className="hero-section">
        <video

          autoPlay
          loop
          muted
          playsInline
          className="hero-video-bg"
          poster="/images/Hero_img.png"
        />
        <div className="hero-video-overlay" />

        <div className="hero-content">
          <div className="badge">
            <span className="badge-text">STRONGER FOUNDATIONS. BETTER FUTURES.</span>
          </div>
          <h1 className="hero-title">
            {t.heroTitlePart1} <span>{t.heroTitlePart2}</span> {t.heroTitlePart3}
          </h1>
          <p className="hero-sub">
            {t.heroSub}
          </p>
          <div className="hero-actions">
            <a href="#solutions" className="btn-primary">
              {t.viewProjects}
            </a>
            <a href="#contact" className="btn-secondary">
              {t.requestConsultation}
            </a>
            <a href="#story" className="btn-secondary" style={{ border: 'none', display: 'flex', alignItems: 'center', gap: '8px' }}>
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="var(--primary-light)" stroke="none"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
              {t.watchStory}
            </a>
          </div>
        </div>
      </section>

      {/* Hero Stats Strip */}
      <div className="stats-strip">
        <div className="stat-item">
          <span className="stat-value">50+</span>
          <span className="stat-label">{t.yearsExperience}</span>
        </div>
        <div className="stat-item">
          <span className="stat-value">120+</span>
          <span className="stat-label">{t.awardsWon}</span>
        </div>
        <div className="stat-item">
          <span className="stat-value">15M+</span>
          <span className="stat-label">{t.acresDesigned}</span>
        </div>
        <div className="stat-item">
          <span className="stat-value">ISO</span>
          <span className="stat-label">{t.isoCertified}</span>
        </div>
      </div>

      {/* Who We Are Section */}
      <section id="who-we-are" className="who-we-are-section">
        <div className="who-we-are-content">
          <div className="badge" style={{ background: 'rgba(76, 175, 80, 0.08)' }}>
            <span className="badge-text" style={{ color: 'var(--primary)' }}>{t.whoWeAre}</span>
          </div>
          <h2>{t.whoWeAreTitle}</h2>
          <p>{t.whoWeAreDesc}</p>
          <a href="#contact" className="btn-primary" style={{ display: 'inline-flex', width: 'fit-content' }}>
            {t.learnMoreUs} <span style={{ marginLeft: '8px' }}>→</span>
          </a>
        </div>
        <div className="who-we-are-image">
          <img src="/images/Hero_img.png" alt="Summit Concrete Solutions Plant" />
        </div>
      </section>

      {/* Our Solutions Section */}
      <section id="solutions" className="solutions-section">
        <div style={{ textAlign: 'center', marginBottom: '60px', padding: '0 20px' }}>
          <div className="badge">
            <span className="badge-text">{t.solutionsTitle}</span>
          </div>
          <p style={{ color: 'var(--text-muted)', maxWidth: '600px', margin: '16px auto 0', fontSize: '1.2rem' }}>
            {t.solutionsSub}
          </p>
        </div>

        <div className="solutions-container">
          <div className="solution-card">
            <img src="/images/readymixconcreteplantaerial.jpg" alt={t.service1} />
            <div className="solution-card-overlay">
              <h3>{t.service1}</h3>
              <p>{t.service1Desc}</p>
              <a href="#contact" className="solution-arrow-btn">→</a>
            </div>
          </div>

          <div className="solution-card">
            <img src="/images/istockphoto-1313022650-1024x1024.jpg" alt={t.service2} />
            <div className="solution-card-overlay">
              <h3>{t.service2}</h3>
              <p>{t.service2Desc}</p>
              <a href="#contact" className="solution-arrow-btn">→</a>
            </div>
          </div>

          <div className="solution-card">
            <img src="/images/istockphoto-1313022678-1024x1024.jpg" alt={t.service3} />
            <div className="solution-card-overlay">
              <h3>{t.service3}</h3>
              <p>{t.service3Desc}</p>
              <a href="#contact" className="solution-arrow-btn">→</a>
            </div>
          </div>
        </div>
      </section>

      {/* Operations Metrics Strip */}
      <div className="operations-strip">
        <div className="op-item">
          <span className="op-value">160+</span>
          <span className="op-label">{t.awardsWon}</span>
        </div>
        <div className="op-item">
          <span className="op-value">900+</span>
          <span className="op-label">{t.transitMixers}</span>
        </div>
        <div className="op-item">
          <span className="op-value">40+</span>
          <span className="op-label">{t.statesServed}</span>
        </div>
        <div className="op-item">
          <span className="op-value">12M+</span>
          <span className="op-label">{t.yardsAnnually}</span>
        </div>
        <div className="op-item">
          <span className="op-value">98%</span>
          <span className="op-label">{t.onTimeDelivery}</span>
        </div>
      </div>

      {/* Industries We Serve Section */}
      <section id="industries" className="industries-section">
        <div style={{ textAlign: 'center', marginBottom: '40px', padding: '0 20px' }}>
          <div className="badge">
            <span className="badge-text">{t.industriesTitle}</span>
          </div>
        </div>

        <div className="industries-scroll-wrapper hide-scrollbar">
          {[
            { name: t.indCommercial, img: "/images/istockphoto-1345955492-1024x1024.jpg" },
            { name: t.indInfrastructure, img: "/images/istockphoto-179969577-1024x1024.jpg" },
            { name: t.indIndustrial, img: "/images/istockphoto-2166976559-1024x1024.jpg" },
            { name: t.indGovernment, img: "/images/istockphoto-2263288423-1024x1024.jpg" },
            { name: t.indEnergy, img: "/images/istockphoto-2263288606-1024x1024.jpg" },
            { name: t.indTransportation, img: "/images/istockphoto-2263816291-1024x1024.jpg" },
            { name: t.indDataCenters, img: "/images/istockphoto-2263817295-1024x1024.jpg" },
            { name: t.indWarehouses, img: "/images/istockphoto-2278348463-1024x1024.jpg" },
          ].map((ind, i) => (
            <div key={i} className="industry-scroll-card">
              <img src={ind.img} alt={ind.name} />
              <div className="industry-scroll-overlay">
                <h3>{ind.name}</h3>
              </div>
            </div>
          ))}
        </div>
      </section>

      {/* Our Process Section */}
      <section className="process-section">
        <div style={{ textAlign: 'center', marginBottom: '60px', padding: '0 20px' }}>
          <div className="badge" style={{ background: 'rgba(76, 175, 80, 0.08)' }}>
            <span className="badge-text" style={{ color: 'var(--primary)' }}>{t.processTitle}</span>
          </div>
        </div>

        <div className="process-flow">
          {[
            { id: '01', title: t.process1Title, desc: t.process1Desc },
            { id: '02', title: t.process2Title, desc: t.process2Desc },
            { id: '03', title: t.process3Title, desc: t.process3Desc },
            { id: '04', title: t.process4Title, desc: t.process4Desc },
            { id: '05', title: t.process5Title, desc: t.process5Desc },
            { id: '06', title: t.process6Title, desc: t.process6Desc },
            { id: '07', title: t.process7Title, desc: t.process7Desc },
          ].map((step, i) => (
            <div key={i} className="process-step">
              <span className="process-number">{step.id}</span>
              <h4>{step.title}</h4>
              <p>{step.desc}</p>
              <div className="process-connector" />
            </div>
          ))}
        </div>
      </section>

      {/* Featured Projects Section */}
      <section id="projects" className="featured-projects-section">
        <div style={{ width: '90%', maxWidth: '1400px', margin: '0 auto 48px' }}>
          <div className="badge">
            <span className="badge-text">{t.featuredTitle}</span>
          </div>
        </div>

        <div className="featured-project-container">
          <div className="featured-project-details">
            <h3>{t.projectName}</h3>
            <span className="featured-project-loc">{t.projectLoc}</span>
            <p className="featured-project-desc">{t.projectSub}</p>

            <div className="featured-project-specs">
              <div className="spec-row">
                <span className="spec-label">45,000+ CY</span>
                <span className="spec-val">{t.projectVol}</span>
              </div>
              <div className="spec-row">
                <span className="spec-label">18 MONTHS</span>
                <span className="spec-val">{t.projectDur}</span>
              </div>
              <div className="spec-row">
                <span className="spec-label">COMMERCIAL</span>
                <span className="spec-val">{t.projectInd}</span>
              </div>
            </div>

            <a href="#contact" className="btn-primary" style={{ display: 'inline-flex', width: 'fit-content' }}>
              {t.viewProjectBtn} <span style={{ marginLeft: '8px' }}>→</span>
            </a>
          </div>

          <div className="featured-project-image">
            <img src="/images/istockphoto-2284955682-1024x1024.jpg" alt="Austin Convention Center Expansion Project" />
          </div>
        </div>
      </section>

      {/* Innovation & Sustainability Grid */}
      <section id="innovation" className="innov-sust-section">
        <div className="innov-column">
          <h3>{t.innovTitle}</h3>
          <p>{t.innovSub}</p>
          <div className="innov-bullets">
            {[t.innov1, t.innov2, t.innov3, t.innov4, t.innov5].map((bullet, i) => (
              <div key={i} className="bullet-item">
                <div className="bullet-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.7" strokeLinecap="round" strokeLinejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                </div>
                <span className="bullet-label">{bullet}</span>
              </div>
            ))}
          </div>
        </div>

        <div className="sust-column">
          <h3>{t.sustTitle}</h3>
          <p>{t.sustSub}</p>
          <div className="sust-bullets">
            {[t.sust1, t.sust2, t.sust3, t.sust4, t.sust5].map((bullet, i) => (
              <div key={i} className="bullet-item">
                <div className="bullet-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.7" strokeLinecap="round" strokeLinejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                </div>
                <span className="bullet-label">{bullet}</span>
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* CTA Strip Banner */}
      <section className="cta-banner">
        <div className="cta-left">
          <h2>{t.readyBuildTitle}</h2>
          <p>{t.readyBuildSub}</p>
        </div>
        <div className="cta-actions">
          <a href="#contact" className="btn-primary" style={{ background: '#ffffff', color: 'var(--primary-dark)', boxShadow: 'none' }}>
            {t.requestQuoteBtn}
          </a>
          <a href="#contact" className="btn-secondary">
            {t.talkEngineerBtn}
          </a>
        </div>
      </section>

      {/* Footer */}
      <footer id="contact">
        <div className="footer-grid">
          <div className="footer-brand">
            <a href="#" className="footer-logo" style={{ display: 'inline-block', marginBottom: '16px' }}>
              <Logo className="app-logo footer-logo-img" />
            </a>
            <p className="footer-desc">
              {t.footerDesc}
            </p>
            <div style={{ marginTop: '16px', color: 'var(--text-muted)' }}>
              <p>Summit Plaza, Suite 400</p>
              <p>Houston, TX 77002</p>
              <p style={{ marginTop: '8px' }}>+1 (800) 555-SUMMIT</p>
              <p>info@summitconcretesolutions.com</p>
            </div>
          </div>

          <div>
            <h4 className="footer-title">{t.navigation}</h4>
            <ul className="footer-links">
              <li><a href="#solutions">{t.history}</a></li>
              <li><a href="#industries">{t.ourValues}</a></li>
              <li><a href="#solutions">{t.locations}</a></li>
              <li><a href="#contact">{t.contact}</a></li>
            </ul>
          </div>

          <div>
            <h4 className="footer-title">{t.company}</h4>
            <ul className="footer-links">
              <li><a href="#who-we-are">{t.quality}</a></li>
              <li><a href="#contact">{t.company}</a></li>
              <li><a href="#innovation">{t.products}</a></li>
              <li><a href="#innovation">{t.capabilities}</a></li>
            </ul>
          </div>

          <div>
            <h4 className="footer-title">{t.subscribe}</h4>
            <p style={{ color: 'var(--text-muted)', fontSize: '14px', marginBottom: '16px', lineHeight: 1.6 }}>
              {t.subscribeText}
            </p>
            <div style={{ display: 'flex', gap: '8px' }}>
              <input type="email" placeholder={t.emailPlaceholder} style={{
                padding: '10px 16px',
                background: 'rgba(255,255,255,0.05)',
                border: '1px solid rgba(255,255,255,0.1)',
                color: 'white',
                borderRadius: '4px',
                flex: 1,
                outline: 'none'
              }} />
              <button style={{
                background: 'var(--primary)',
                color: 'white',
                border: 'none',
                padding: '0 16px',
                borderRadius: '4px',
                cursor: 'pointer',
                fontWeight: 700
              }}>{t.join}</button>
            </div>
          </div>
        </div>

        <div className="footer-bottom">
          <div>&copy; {new Date().getFullYear()} Summit Concrete Solutions. {t.rightsReserved}</div>
          <div style={{ display: 'flex', gap: '24px' }}>
            <a href="#" style={{ color: 'var(--text-muted)', textDecoration: 'none' }}>{t.privacyPolicy}</a>
            <a href="#" style={{ color: 'var(--text-muted)', textDecoration: 'none' }}>{t.termsOfService}</a>
          </div>
        </div>
      </footer>
    </>
  );
}

export default App;
