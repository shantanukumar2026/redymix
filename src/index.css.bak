@import url('https://fonts.googleapis.com/css2?family=Barlow+Condensed:ital,wght@0,400;0,700;0,900;1,900&family=Inter:wght@300;400;500;700;800&display=swap');

:root {
  --primary: #2E7D32;
  --primary-light: #4CAF50;
  --primary-dark: #1B5E20;
  --accent: #81C784;
  --bg-dark: #051408;
  --bg-card: rgba(10, 30, 15, 0.4);
  --text-main: #ffffff;
  --text-muted: rgba(255, 255, 255, 0.7);
}

* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

body {
  background-color: var(--bg-dark);
  color: var(--text-main);
  font-family: 'Inter', sans-serif;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}

h1,
h2,
h3,
h4,
.font-display {
  font-family: 'Barlow Condensed', sans-serif;
}

.hide-scrollbar::-webkit-scrollbar {
  display: none;
}

.hide-scrollbar {
  -ms-overflow-style: none;
  scrollbar-width: none;
}

/* Header */
header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 50;
  transition: all 0.3s ease;
}

.top-bar {
  background: var(--primary-dark);
  height: 160px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 60px;
}

.logo-container {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  background: white;
  color: var(--primary-dark);
  text-decoration: none;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 28px;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 2px;
  height: 100%;
  align-self: stretch;
  padding: 0 20px;
  width: auto;
  min-width: auto;
}

/* App SVG logo (inline) - scalable and fillable via CSS */
.app-logo {
  display: inline-block;
  color: var(--primary-dark);
  line-height: 0;
}

.app-logo svg {
  display: block;
  height: 100%;
  width: auto;
}

/* .logo-img {
  display: block;
  height: 100%;
  max-height: 120px;
  width: auto;
  object-fit: contain;
  border-radius: 8px;
  padding: 16px 12px;
} */


.logo-img {
  display: block;
  height: 100%;
  max-height: 120px;
  width: 100%;
  object-fit: fill;
  border-radius: 8px;
  /* padding: 16px 12px; */
}









.header-logo {
  height: 100%;
}

.footer-logo-img {
  height: 120px;
}

.logo-container span {
  color: var(--primary-light);
}

.top-links {
  display: flex;
  align-items: center;
  gap: 32px;
}

.top-links a,
.top-links button {
  color: white;
  text-decoration: none;
  font-size: 13px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  display: flex;
  align-items: center;
  gap: 8px;
  transition: opacity 0.2s;
  background: none;
  border: none;
  cursor: pointer;
  font-family: inherit;
}

.top-links a:hover,
.top-links button:hover {
  opacity: 0.7;
}

.bottom-bar {
  background: white;
  height: 56px;
  border-bottom: 1px solid var(--accent);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 60px;
}

.bottom-nav {
  display: flex;
  align-items: center;
  gap: 40px;
  height: 100%;
}

.bottom-nav button {
  background: none;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 6px;
  color: var(--primary-dark);
  font-size: 15px;
  font-weight: 800;
  text-transform: uppercase;
  height: 100%;
  position: relative;
  font-family: inherit;
}

.nav-underline {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  height: 3px;
  background: var(--primary-dark);
  width: 0%;
  transition: width 0.3s ease;
}

.bottom-nav button:hover .nav-underline {
  width: 100%;
}

.search-box {
  position: relative;
  width: 320px;
}

.search-box input {
  width: 100%;
  padding: 10px 16px 10px 44px;
  background: rgba(230, 245, 235, 0.8);
  border: 1px solid rgba(76, 175, 80, 0.5);
  border-radius: 4px;
  font-size: 14px;
  font-weight: 500;
  color: var(--primary-dark);
  font-family: inherit;
  outline: none;
}

/* Hero Section - Full Screen Video Design */
.hero-section {
  position: relative;
  height: 100vh;
  min-height: 850px;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-dark);
  padding: 0 60px;
  overflow: hidden;
}

.hero-video-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: 1;
}

.hero-video-overlay {
  position: absolute;
  inset: 0;
  background: rgba(5, 20, 8, 0.75);
  /* Dark transparent green tint for high contrast */
  z-index: 2;
}

.hero-content {
  position: relative;
  z-index: 10;
  max-width: 900px;
  text-align: center;
  margin: 0 auto;
  animation: slideUp 1s forwards ease-out;
  opacity: 0;
  transform: translateY(30px);
  padding-top: 220px;
  /* Comfortably clears the fixed header height */
  padding-bottom: 80px;
}

@keyframes slideUp {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(76, 175, 80, 0.15);
  border: 1px solid rgba(76, 175, 80, 0.3);
  border-radius: 50px;
  padding: 6px 16px;
  width: fit-content;
  margin-bottom: 24px;
}

.badge-text {
  color: var(--primary-light);
  font-size: 13px;
  font-weight: 800;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.hero-title {
  font-size: clamp(2.5rem, 5vw, 5rem);
  font-weight: 900;
  line-height: 1.1;
  color: #fff;
  text-transform: uppercase;
  margin-bottom: 24px;
}

.hero-title span {
  color: var(--primary-light);
}

.hero-sub {
  color: var(--text-muted);
  font-size: 1.2rem;
  font-weight: 400;
  line-height: 1.6;
  margin-bottom: 40px;
  width: 100%;
}

.hero-actions {
  display: flex;
  gap: 20px;
  justify-content: center;
}

.btn-primary {
  display: flex;
  align-items: center;
  gap: 12px;
  background: var(--primary);
  color: #fff;
  text-decoration: none;
  padding: 16px 32px;
  border-radius: 4px;
  font-size: 14px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  border: 1px solid transparent;
  transition: all 0.3s;
  box-shadow: 0 10px 20px rgba(46, 125, 50, 0.3);
}

.btn-primary:hover {
  background: var(--primary-dark);
  transform: translateY(-2px);
  box-shadow: 0 15px 25px rgba(46, 125, 50, 0.4);
}

.btn-secondary {
  display: flex;
  align-items: center;
  gap: 12px;
  background: transparent;
  color: #fff;
  text-decoration: none;
  padding: 16px 32px;
  border-radius: 4px;
  font-size: 14px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  border: 1px solid rgba(255, 255, 255, 0.2);
  transition: all 0.3s;
}

.btn-secondary:hover {
  background: rgba(255, 255, 255, 0.05);
  border-color: #fff;
}

/* Stats Strip */
.stats-strip {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  background: rgba(5, 20, 8, 0.95);
  border-bottom: 2px solid var(--primary);
  padding: 32px 60px;
  gap: 24px;
  z-index: 10;
  position: relative;
  margin-top: 0;
}

.stats-strip .stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  border-right: 1px solid rgba(255, 255, 255, 0.1);
}

.stats-strip .stat-item:last-child {
  border-right: none;
}

.stats-strip .stat-value {
  font-size: 2.5rem;
  font-weight: 900;
  color: var(--primary-light);
  line-height: 1.1;
}

.stats-strip .stat-label {
  font-size: 12px;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-top: 8px;
}

/* Who We Are Section (Light Theme) */
.who-we-are-section {
  background: #fdfdfd;
  color: #121212;
  padding: 120px 60px;
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  gap: 80px;
  align-items: center;
}

.who-we-are-content h2 {
  font-size: 3rem;
  font-weight: 900;
  text-transform: uppercase;
  margin-bottom: 24px;
  color: #121212;
  line-height: 1.1;
}

.who-we-are-content p {
  font-size: 1.1rem;
  line-height: 1.8;
  color: #555555;
  margin-bottom: 32px;
}

.who-we-are-image img {
  width: 100%;
  height: 420px;
  object-fit: cover;
  border-radius: 12px;
  box-shadow: 0 20px 45px rgba(0, 0, 0, 0.12);
}

/* Solutions Section */
.solutions-section {
  background: var(--bg-dark);
  padding: 120px 0;
}

.solutions-container {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32px;
  padding: 0 60px;
  margin-top: 60px;
}

.solution-card {
  position: relative;
  height: 460px;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 15px 30px rgba(0, 0, 0, 0.3);
  transition: all 0.4s ease;
}

.solution-card img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s ease;
}

.solution-card:hover img {
  transform: scale(1.08);
}

.solution-card-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(5, 20, 8, 0.95) 30%, rgba(5, 20, 8, 0.4) 70%, rgba(5, 20, 8, 0.1));
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 40px;
}

.solution-card h3 {
  font-size: 2.2rem;
  font-weight: 900;
  color: white;
  text-transform: uppercase;
  margin-bottom: 12px;
}

.solution-card p {
  color: var(--text-muted);
  font-size: 1rem;
  line-height: 1.5;
  margin-bottom: 24px;
}

.solution-arrow-btn {
  width: 48px;
  height: 48px;
  border-radius: 4px;
  background: var(--primary);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.3s;
  cursor: pointer;
  text-decoration: none;
  font-weight: bold;
}

.solution-card:hover .solution-arrow-btn {
  background: var(--primary-light);
}

/* Operations Metrics Strip */
.operations-strip {
  background: var(--primary-dark);
  padding: 40px 60px;
  display: flex;
  justify-content: space-around;
  align-items: center;
  flex-wrap: wrap;
  border-top: 1px solid rgba(255, 255, 255, 0.1);
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  gap: 32px;
}

.op-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.op-value {
  font-size: 2.5rem;
  font-weight: 900;
  color: #ffffff;
}

.op-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.1em;
  color: var(--accent);
  text-transform: uppercase;
  margin-top: 4px;
}

/* Industries We Serve Scrollable */
.industries-section {
  background: var(--bg-dark);
  padding: 120px 0;
}

.industries-scroll-wrapper {
  overflow-x: auto;
  display: flex;
  gap: 20px;
  padding: 40px 60px;
}

.industry-scroll-card {
  flex: 0 0 260px;
  height: 340px;
  position: relative;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 10px 25px rgba(0, 0, 0, 0.25);
  cursor: pointer;
  transition: all 0.3s ease;
}

.industry-scroll-card img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s;
}

.industry-scroll-card:hover img {
  transform: scale(1.06);
}

.industry-scroll-overlay {
  position: absolute;
  inset: 0;
  background: rgba(5, 20, 8, 0.65);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20px;
  text-align: center;
  transition: background 0.3s;
}

.industry-scroll-card:hover .industry-scroll-overlay {
  background: rgba(46, 125, 50, 0.85);
}

.industry-scroll-card h3 {
  font-size: 1.6rem;
  font-weight: 800;
  color: white;
  text-transform: uppercase;
  letter-spacing: 1px;
}

/* Our Process Timeline (Light Theme) */
.process-section {
  padding: 120px 60px;
  background: #fdfdfd;
  color: #121212;
}

.process-flow {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 20px;
  margin-top: 60px;
  position: relative;
}

.process-step {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  position: relative;
  z-index: 5;
}

.process-number {
  font-size: 2.2rem;
  font-weight: 900;
  color: var(--primary-light);
  line-height: 1;
  margin-bottom: 8px;
}

.process-step h4 {
  font-size: 1.1rem;
  font-weight: 800;
  color: #121212;
  text-transform: uppercase;
  margin-bottom: 8px;
}

.process-step p {
  font-size: 0.9rem;
  color: #666666;
  line-height: 1.5;
}

.process-connector {
  position: absolute;
  top: 18px;
  left: 55px;
  right: -20px;
  height: 2px;
  background: #e0e0e0;
  z-index: 1;
}

.process-step:last-child .process-connector {
  display: none;
}

/* Featured Projects Section (Dark Theme) */
.featured-projects-section {
  background: #0a0a0a;
  padding: 120px 0;
}

.featured-project-container {
  display: grid;
  grid-template-columns: 1.3fr 1.7fr;
  width: 90%;
  max-width: 1400px;
  margin: 0 auto;
  background: #141414;
  border-radius: 20px;
  overflow: hidden;
  box-shadow: 0 30px 60px rgba(0, 0, 0, 0.55);
}

.featured-project-details {
  padding: 60px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  background: #181818;
}

.featured-project-details h3 {
  font-size: 2.8rem;
  font-weight: 900;
  text-transform: uppercase;
  line-height: 1.1;
  margin-bottom: 8px;
  color: white;
}

.featured-project-loc {
  font-size: 1rem;
  color: var(--primary-light);
  font-weight: 700;
  margin-bottom: 24px;
}

.featured-project-desc {
  font-size: 1rem;
  color: var(--text-muted);
  line-height: 1.6;
  margin-bottom: 32px;
}

.featured-project-specs {
  display: flex;
  flex-direction: column;
  gap: 16px;
  margin-bottom: 40px;
}

.spec-row {
  display: flex;
  justify-content: space-between;
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  padding-bottom: 10px;
}

.spec-label {
  font-size: 13px;
  text-transform: uppercase;
  color: var(--text-muted);
  letter-spacing: 1px;
}

.spec-val {
  font-weight: 800;
  color: white;
}

.featured-project-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  min-height: 520px;
}

/* Innovation & Sustainability Grid */
.innov-sust-section {
  background: #050505;
  padding: 120px 60px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
}

.innov-column,
.sust-column {
  background: #0d0d0d;
  padding: 50px;
  border-radius: 16px;
  border: 1px solid rgba(255, 255, 255, 0.03);
}

.innov-column h3,
.sust-column h3 {
  font-size: 2.4rem;
  font-weight: 900;
  color: white;
  text-transform: uppercase;
  margin-bottom: 16px;
}

.innov-column p,
.sust-column p {
  color: var(--text-muted);
  line-height: 1.6;
  margin-bottom: 40px;
}

.innov-bullets,
.sust-bullets {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.bullet-item {
  display: flex;
  align-items: center;
  gap: 16px;
}

.bullet-icon {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: rgba(76, 175, 80, 0.1);
  color: var(--primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.bullet-label {
  font-weight: 800;
  font-size: 14px;
  letter-spacing: 1px;
  color: white;
}

/* CTA Banner Section */
.cta-banner {
  background: linear-gradient(135deg, var(--primary-dark), #031006);
  padding: 80px 60px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 2px solid var(--primary-light);
  gap: 40px;
}

.cta-left h2 {
  font-size: 3rem;
  font-weight: 900;
  color: white;
  text-transform: uppercase;
  margin-bottom: 8px;
}

.cta-left p {
  font-size: 1.2rem;
  color: var(--text-muted);
}

.cta-actions {
  display: flex;
  gap: 20px;
}

/* Responsive Overrides */
@media (max-width: 1024px) {

  .who-we-are-section,
  .featured-project-container,
  .innov-sust-section {
    grid-template-columns: 1fr;
  }

  .who-we-are-section {
    padding: 80px 30px;
  }

  .solutions-container {
    grid-template-columns: 1fr;
  }

  .stats-strip {
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    padding: 30px;
  }

  .stats-strip .stat-item {
    border-right: none;
  }

  .process-flow {
    grid-template-columns: 1fr;
    gap: 30px;
  }

  .process-connector {
    display: none;
  }

  .cta-banner {
    flex-direction: column;
    text-align: center;
    padding: 60px 30px;
  }
}

footer {
  background: var(--bg-dark);
  color: white;
  padding: 80px 60px 40px;
  border-top: 1px solid rgba(255, 255, 255, 0.05);
}

.footer-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1.5fr;
  gap: 40px;
  width: 100%;
  margin: 0 auto;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  padding-bottom: 60px;
}

.footer-brand {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.footer-logo {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 32px;
  font-weight: 900;
  text-transform: uppercase;
  color: white;
  letter-spacing: 2px;
  display: flex;
  align-items: center;
  gap: 12px;
}

.footer-logo span {
  color: var(--primary-light);
}

.footer-desc {
  color: var(--text-muted);
  font-size: 15px;
  line-height: 1.8;
  max-width: 400px;
}

.footer-title {
  font-size: 16px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 24px;
  color: var(--primary-light);
}

.footer-links {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.footer-links a {
  color: var(--text-muted);
  text-decoration: none;
  font-size: 14px;
  transition: color 0.2s;
}

.footer-links a:hover {
  color: white;
}

.footer-bottom {
  width: 100%;
  margin: 40px auto 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  color: var(--text-muted);
  font-size: 14px;
}

@media (max-width: 1024px) {
  .hero-container {
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    padding: 0 30px;
  }

  .command-center {
    margin-top: 40px;
    width: 100%;
    max-width: 400px;
    margin-right: 0;
  }

  .portfolio-grid {
    grid-template-columns: 1fr;
    padding: 80px 30px;
    gap: 40px;
  }

  .portfolio-media {
    margin-left: 0;
    height: 40vh;
  }

  .footer-grid {
    grid-template-columns: 1fr 1fr;
  }
}

@media (max-width: 768px) {
  .footer-grid {
    grid-template-columns: 1fr;
  }

  .top-links,
  .bottom-bar {
    display: none;
  }

  .extreme-edge {
    display: none;
  }
}